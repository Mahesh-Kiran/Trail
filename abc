class EncodeNumber {
    static String encode2(int n) {
        n = n + 1;
        StringBuilder sb = new StringBuilder("");
        while (n != 0) {
            sb.append(n & 1);
            n = n >> 1;
        }
        sb.reverse();
        System.out.println("Binary string " + sb.toString());
        return sb.toString().substring(1);
    }

    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        int num = sc.nextInt();
        System.out.print(new EncodeNumber().encode2(num));
    }
