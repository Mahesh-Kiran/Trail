class CountingBits {
    public static int[] CountSetBits(int n) {
        int r[] = new int[n + 1];
        r[0] = 0;
        for (int i = 1; i <= n; i++) {
            int ct = 0;
            int x = i;
            while (x > 0) {
                x &= (x - 1);
                ct++;
            }
            r[i] = ct;
        }
        return r;
    }

    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int n = s.nextInt();
        int r[] = new int[n + 1];
        r = CountSetBits(n);
        System.out.print(Arrays.toString(r));
    }
