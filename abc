public class ArrayRotation{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        int arr[] = new int[n];
        for(int i=0;i<n;i++)
        arr[i]  = sc.nextInt();
        int k = sc.nextInt();
        
        Rotate(n,arr,k);
        System.out.println(Arrays.toString(arr));
    }
    
    static void Rotate(int n,int arr[],int k){
        if(k == 0){
            return;
        }
        k = k%n;
        reverse(arr,0,n-1);
        reverse(arr,0,k-1);
        reverse(arr,k,n-1);
        
    }
    
    static void reverse(int arr[],int start,int end){
        while(start<end){
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;
            start++;end--;
        }
    }
}import java.util.*;

