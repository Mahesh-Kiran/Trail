class TreapNode {
    int key, priority;
    TreapNode left, right;
}

public class Treap {

    // Right rotation
    public static TreapNode rightRotate(TreapNode y) {
        TreapNode x = y.left;
        TreapNode T2 = x.right;
        x.right = y;
        y.left = T2;
        return x;
    }

    // Left rotation
    public static TreapNode leftRotate(TreapNode x) {
        TreapNode y = x.right;
        TreapNode T2 = y.left;
        y.left = x;
        x.right = T2;
        return y;
    }

    // Create a new node
    public static TreapNode newNode(int key) {
        TreapNode temp = new TreapNode();
        temp.key = key;
        temp.priority = (int) (Math.random() * 100);
        temp.left = temp.right = null;
        return temp;
    }

    // Insert a node
    public static TreapNode insertNode(TreapNode root, int key) {
        if (root == null) {
            return newNode(key);
        }
        if (key <= root.key) {
            root.left = insertNode(root.left, key);
            if (root.left.priority > root.priority) {
                root = rightRotate(root);
            }
        } else {
            root.right = insertNode(root.right, key);
            if (root.right.priority > root.priority) {
                root = leftRotate(root);
            }
        }
        return root;
    }

    // Delete a node
    public static TreapNode deleteNode(TreapNode root, int key) {
        if (root == null) return root;

        if (key < root.key) {
            root.left = deleteNode(root.left, key);
        } else if (key > root.key) {
            root.right = deleteNode(root.right, key);
        } else {
            // Node with one child or no child
            if (root.left == null) {
                root = root.right;
            } else if (root.right == null) {
                root = root.left;
            } else {
                // Node with two children
                if (root.left.priority < root.right.priority) {
                    root = leftRotate(root);
                    root.left = deleteNode(root.left, key);
                } else {
                    root = rightRotate(root);
                    root.right = deleteNode(root.right, key);
                }
            }
        }
        return root;
    }

    // Search a node
    public static TreapNode search(TreapNode root, int key) {
        if (root == null || root.key == key) return root;
        if (root.key < key) return search(root.right, key);
        return search(root.left, key);
    }

    // Preorder traversal
    static void preorder(TreapNode root) {
        if (root != null) {
            System.out.println("key: " + root.key + " | priority: " + root.priority);
            preorder(root.left);
            preorder(root.right);
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int arr[] = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        TreapNode root = null;
        for (int a : arr) {
            root = insertNode(root, a);
        }

        System.out.println("Preorder traversal:");
        preorder(root);

        System.out.println("Enter item to search: ");
        int key = sc.nextInt();
        TreapNode result = search(root, key);
        if (result != null) {
            System.out.println("Search result: key = " + result.key + ", priority = " + result.priority);
        } else {
            System.out.println("Key " + key + " not found");
        }

        do {
            System.out.println("Enter item to delete (-1 to stop): ");
            key = sc.nextInt();
            if (key == -1) break;
            root = deleteNode(root, key);
            System.out.println("After delete:");
            preorder(root);
        } while (root != null);

        sc.close();
    }
}import java.util.*;

public class ValidWordAbbreviation
{
    public boolean validWordAbbreviation(String word, String abbr)
    {
        int pw = 0, pa = 0;

        while (pw < word.length() && pa < abbr.length())
        {
            if (word.charAt(pw) == abbr.charAt(pa))
            {
                ++pw;
                ++pa;
                continue;
            }

            if (abbr.charAt(pa) <= '0' || abbr.charAt(pa) > '9')
            {
                return false;
            }

            int start = pa;

            while (pa < abbr.length() && abbr.charAt(pa) >= '0' && abbr.charAt(pa) <= '9')
            {
                ++pa;
            }

            int num = Integer.valueOf(abbr.substring(start, pa));

            pw += num;
        }

        return pw == word.length() && pa == abbr.length();
    }

    public static void main(String args[])
    {
        Scanner in = new Scanner(System.in);

        System.out.println("Enter word");

        String word = in.next();

        System.out.println("Enter Abbreviation");

        String abbrv = in.next();

        System.out.println(new ValidWordAbbreviation().validWordAbbreviation(word, abbrv));
    }
