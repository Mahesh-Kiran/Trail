public class KthSmallestSubarraySum{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int t = sc.nextInt();
        int arr[] = new int[n];
        for(int i=0;i<n;i++)
        arr[i]  = sc.nextInt();
        
        System.out.println(kth(n,t,arr));
    }
    
    static int kth(int n,int t,int arr[]){
        int low = Integer.MAX_VALUE;
        int high = 0;
        
        for(int i=0;i<n;i++){
            low = Math.min(low,arr[i]);
            high+=arr[i];
        }
        
        while(low<high){
            int mid = (low+high)/2;
            if((coutsub(arr,mid,n))>=t){
                high=mid;
            }
            else{
                low=mid+1;
            }
        }
        return low;
    }
    
    static int coutsub(int arr[],int m,int n){
        int sum = 0;
        int count = 0;
        int left = 0;
        
        for(int i=0;i<n;i++){
            sum+= arr[i];
            
            while(sum>m){
                sum -= arr[left];
                left++;
            }
            count += (i-left+1);
        }
        return count;
    }
}

